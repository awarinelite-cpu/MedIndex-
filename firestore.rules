rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Drugs: public read, admin write only
    match /drugs/{drugId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // App config (system conditions, settings): admin write only
    match /app_config/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Admin records: read own record only, no writes
    match /admins/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }

    // All other collections: authenticated non-anonymous users only
    match /{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
  }
}
