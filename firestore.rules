rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // Drugs — public read, signed-in write
    match /drugs/{drugId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // App config (conditions, settings) — public read, signed-in write
    match /app_config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Admins — only read own record
    match /admins/{email} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Per-user data (saved drug lists, etc.) — owner or admin only, never
    // other users. Admins get read access so the admin panel can show a
    // user's saved lists; only the owner can write their own data.
    match /users/{uid} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read:  if request.auth != null && (request.auth.uid == uid || isAdmin());
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Search history — any signed-in user can log their own searches;
    // only admins can read the log (it's not meant to be browsable by users).
    match /search_logs/{logId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow read:   if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Everything else — signed-in only
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
