rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // True only for a signed-in user whose email has a corresponding
    // admins/{email} doc with role == 'admin' — the SAME check the app's
    // own AuthContext already uses client-side to decide what UI to show.
    // This keeps one single source of truth for "who is an admin" instead
    // of introducing separate custom-claims infrastructure.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
        && get(/databases/$(database)/documents/admins/$(request.auth.token.email)).data.role == 'admin';
    }

    // Drugs — public read, ADMIN-ONLY write.
    // Previously any signed-in account (open signup, no approval) could
    // write here directly via the SDK, bypassing the app's own isAdmin UI
    // gating entirely — able to overwrite or delete any drug record.
    match /drugs/{drugId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // App config (conditions, settings) — public read, ADMIN-ONLY write.
    // Same issue as /drugs — condition taxonomy is shared/global data.
    match /app_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins — a signed-in user may read their OWN admin record only
    // (to check their own status), never someone else's. Never
    // client-writable — promoting an admin requires the Firebase
    // Console or Admin SDK, which is the correct amount of friction.
    match /admins/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }

    // Each signed-in user's own saved drug lists — owner only.
    // Previously the catch-all rule below let ANY signed-in user read or
    // write ANY other user's personal lists (no ownership check at all).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /lists/{listId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Everything else — deny by default. Any new collection added later
    // must get its own explicit rule above; nothing is implicitly open.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
