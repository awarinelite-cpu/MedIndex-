rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Drug reference database ──────────────────────────────────────────
    // Anyone can read (public reference app).
    // Only signed-in admin users can write — anonymous auth is NOT allowed.
    match /drugs/{drugId} {
      allow read: if true;
      allow write: if request.auth != null && !request.auth.token.firebase.sign_in_provider.matches('anonymous');
    }

    // ── Admin records ────────────────────────────────────────────────────
    match /admins/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }

    // ── All other collections ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if request.auth != null && !request.auth.token.firebase.sign_in_provider.matches('anonymous');
    }
  }
}
